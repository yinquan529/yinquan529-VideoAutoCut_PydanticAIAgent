# OpenAI API key (required for default model)
OPENAI_API_KEY=sk-your-key-here

# PydanticAI model identifier
# Examples: openai:gpt-4o-mini, openai:gpt-4o, anthropic:claude-3-5-sonnet-latest
MODEL_NAME=openai:gpt-4o-mini

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Path to FFmpeg executable (optional, uses system PATH if not set)
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
