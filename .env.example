# =============================================================================
# VideoAutoCut Configuration
# Copy this file to .env and fill in the required values.
# =============================================================================

# --- Hunyuan API (required) ---
HUNYUAN_API_KEY=your-hunyuan-api-key-here
HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1

# --- Model ---
# PydanticAI model identifier (default: openai:hunyuan-turbos-latest)
# MODEL_NAME=openai:hunyuan-turbos-latest

# --- Tool Paths ---
# Path to ffmpeg executable (default: ffmpeg, uses system PATH)
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# Path to ffprobe executable (default: ffprobe, uses system PATH)
# FFPROBE_PATH=C:\ffmpeg\bin\ffprobe.exe

# --- Directories ---
# Temporary directory for extracted frames (default: .video_autocut/frames)
# TEMP_FRAMES_DIR=.video_autocut/frames
# Directory for final output files (default: .video_autocut/output)
# OUTPUT_DIR=.video_autocut/output

# --- Behaviour ---
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# LOG_LEVEL=INFO
# Max retries for LLM API calls, 0-10 (default: 3)
# MAX_RETRIES=3
# Timeout for LLM API calls in seconds, 5-600 (default: 60)
# REQUEST_TIMEOUT_SECONDS=60
